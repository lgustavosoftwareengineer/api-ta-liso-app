# AWS Secrets Manager
# Nome do secret que contém todas as configurações da aplicação
AWS_SECRETS_NAME=talisoapp/develop
AWS_REGION=us-east-1

# Credenciais AWS (somente para desenvolvimento local)
# Em produção, use uma IAM Role associada à instância/task
AWS_ACCESS_KEY_ID=sua-access-key-id
AWS_SECRET_ACCESS_KEY=sua-secret-access-key

# Local envs
# CORS: lista em JSON (ex.: ["http://localhost:5173"])
ALLOWED_ORIGINS=["http://localhost:5173"]
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taliso
API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=um-dominio-de-email-verificado

# OpenRouter (chat do app; default: google/gemini-2.5-flash)
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
# OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Telegram bot (opcional)
TELEGRAM_BOT_TOKEN=token-do-BotFather
TELEGRAM_WEBHOOK_SECRET=secret-aleatorio-para-X-Telegram-Bot-Api-Secret-Token
